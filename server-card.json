{
  "name": "shipswiftcomponents",
  "title": "ShipSwift Component MCP",
  "description": "A paid remote MCP for ShipSwift, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://shipswiftcomponents.clauxel.com/",
  "documentationUrl": "https://shipswiftcomponents.clauxel.com/mcp/",
  "endpointUrl": "https://shipswiftcomponents.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://shipswiftcomponents.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://shipswiftcomponents.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://shipswiftcomponents.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "indie",
        "name": "Indie",
        "monthlyUsd": 39
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 119
      },
      {
        "id": "studio",
        "name": "Studio",
        "monthlyUsd": 299
      }
    ]
  },
  "tools": [
